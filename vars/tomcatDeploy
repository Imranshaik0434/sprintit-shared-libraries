
def call(tomcatIp,tomcatdevcreds){
sshagent(['tomcatdevcreds']) {
                 sh """
                     scp -o StrictHostKeyChecking=no target/oniline-banking.war ec2-user@${tomcatIp}:/opt/tomcat11/webapps/
